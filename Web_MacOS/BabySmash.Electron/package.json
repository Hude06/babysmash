{
  "name": "babysmash-electron",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "sync-assets": "npm --prefix ../BabySmash.Web run sync-assets",
    "dev": "concurrently \"npm --prefix ../BabySmash.Web run dev -- --host 127.0.0.1 --port 5173\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build:web": "npm --prefix ../BabySmash.Web run build",
    "build:mac": "npm run sync-assets && npm run build:web && electron-builder --mac dmg zip"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "electron": "^37.2.4",
    "electron-builder": "^26.0.12",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.babysmash.desktop",
    "productName": "BabySmash",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      {
        "from": "../BabySmash.Web/dist",
        "to": "web-dist"
      }
    ],
    "mac": {
      "category": "public.app-category.games",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
